<section class="relative text-black w-full overflow-x-hidden">
    <div
        class="relative w-full overflow-hidden"
        id="flores-arriba"
        style="opacity: 1 !important;"
    >
        <img
            src="/imagenes/FloresArriba.webp"
            alt="Flores decorativas"
            class="w-full h-auto object-cover object-center block"
            style="opacity: 1 !important;"
        />

        <div
            class="absolute left-1/2 transform -translate-x-1/2 top-[100px] sm:top-16 md:top-12 lg:top-8 xl:top-4 z-50"
            id="corona"
        >
            <img
                src="/imagenes/Corona.webp"
                alt="Corona de quinceañera"
                class="w-24 h-auto sm:w-24 sm:h-24 md:w-28 md:h-28 lg:w-32 lg:h-32 xl:w-36 xl:h-36 object-contain mx-auto"
            />
        </div>
    </div>

    <div class="relative w-full sm:pt-40 md:pt-48 overflow-hidden px-4">
        <div class="flex justify-center w-full">
            <div class="text-center z-10 max-w-4xl w-full">
                <div
                    class="relative text-center z-30 mb-8 w-full"
                    id="titulo-container"
                >
                    <h1
                        class="font-crimson text-2xl sm:text-2xl md:text-3xl lg:text-4xl xl:text-5xl text-[#9A7B2F] font-bold tracking-wider"
                        id="titulo"
                    >
                        MIS XV AÑOS
                    </h1>
                </div>

                <div
                    class="flex items-center justify-center mb-8 w-full"
                    id="nombre-container"
                >
                    <h2
                        class="font-great-vibes text-6xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl text-[#C9A94B] tracking-wide leading-tight"
                        id="nombre-typewriter"
                    >
                    </h2>
                </div>

                <div
                    class="relative w-full overflow-visible"
                    id="foto-container"
                >
                    <div
                        id="flores-foto-izq"
                        class="absolute -left-4 sm:left-0 top-32 sm:top-24 md:top-20 lg:top-16 flex-shrink-0 z-30"
                    >
                        <img
                            src="/imagenes/FlorLateral.webp"
                            alt="Flores izquierda"
                            class="w-14 h-auto object-contain"
                        />
                    </div>

                    <div
                        id="flores-foto-der"
                        class="absolute -right-4 sm:right-0 top-32 sm:top-24 md:top-20 lg:top-16 flex-shrink-0 z-30"
                    >
                        <img
                            src="/imagenes/FlorLateral.webp"
                            alt="Flores derecha"
                            class="w-14 h-auto object-contain scale-x-[-1]"
                        />
                    </div>

                    <div class="relative flex justify-center">
                        <img
                            src="/imagenes/mis.png"
                            alt="Foto de quinceañera"
                            class="w-full max-w-[65vw] h-auto sm:max-w-[55vw] md:max-w-[45vw] lg:max-w-[35vw] xl:max-w-[30vw] object-contain"
                            id="foto-quinceañera"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- MARIPOSAS VOLANDO con aleteo de alas -->
    <div
        id="fn-mariposas-nombre"
        class="absolute inset-0 w-full h-full pointer-events-none overflow-hidden"
    >
        <!-- Derecha arriba - mediana -->
        <div class="mariposa-fn absolute w-8 sm:w-10"
             style="top: 45%; right: 4%; animation: volar1 7s ease-in-out infinite;">
            <img src="/imagenes/mariposadorada.png" alt="Mariposa"
                 class="w-full h-auto object-contain"
                 style="animation: aletear 0.9s ease-in-out infinite;" />
        </div>
        <!-- Derecha medio - pequeña -->
        <div class="mariposa-fn absolute w-5 sm:w-7"
             style="top: 60%; right: 8%; animation: volar3 8s ease-in-out infinite 3s;">
            <img src="/imagenes/mariposadorada.png" alt="Mariposa"
                 class="w-full h-auto object-contain"
                 style="animation: aletear 0.75s ease-in-out infinite 0.2s;" />
        </div>
        <!-- Derecha abajo - mediana-pequeña -->
        <div class="mariposa-fn absolute w-6 sm:w-8"
             style="top: 52%; right: 2%; animation: volar1 9s ease-in-out infinite 5s;">
            <img src="/imagenes/mariposadorada.png" alt="Mariposa"
                 class="w-full h-auto object-contain"
                 style="animation: aletear 1.0s ease-in-out infinite 0.4s;" />
        </div>

        <!-- Izquierda arriba - mediana -->
        <div class="mariposa-fn absolute w-8 sm:w-10"
             style="top: 43%; left: 4%; animation: volar2 9s ease-in-out infinite 1s;">
            <img src="/imagenes/mariposadorada.png" alt="Mariposa"
                 class="w-full h-auto object-contain"
                 style="animation: aletear-izq 0.9s ease-in-out infinite 0.1s;" />
        </div>
        <!-- Izquierda medio - pequeña -->
        <div class="mariposa-fn absolute w-5 sm:w-7"
             style="top: 57%; left: 8%; animation: volar2 7s ease-in-out infinite 4s;">
            <img src="/imagenes/mariposadorada.png" alt="Mariposa"
                 class="w-full h-auto object-contain"
                 style="animation: aletear-izq 0.75s ease-in-out infinite 0.3s;" />
        </div>
        <!-- Izquierda abajo - mediana-pequeña -->
        <div class="mariposa-fn absolute w-6 sm:w-8"
             style="top: 50%; left: 2%; animation: volar4 8s ease-in-out infinite 2s;">
            <img src="/imagenes/mariposadorada.png" alt="Mariposa"
                 class="w-full h-auto object-contain"
                 style="animation: aletear-izq 1.0s ease-in-out infinite 0.5s;" />
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        console.log("Iniciando animaciones...");

        // FLORES ARRIBA - Sin animación para mantener opacidad completa
        gsap.set("#flores-arriba", { clearProps: "all" });

        // CORONA - Zoom in
        gsap.fromTo(
            "#corona",
            { opacity: 0, scale: 0.5 },
            {
                opacity: 1,
                scale: 1,
                duration: 1.2,
                ease: "back.out(1.2)",
                delay: 0.3,
            },
        );

        // TÍTULO - Fade in de arriba
        gsap.fromTo(
            "#titulo",
            { opacity: 0, y: 30 },
            { opacity: 1, y: 0, duration: 1, ease: "power2.out", delay: 0.5 },
        );

        // MARIPOSAS - Fade in suave del contenedor
        gsap.set("#fn-mariposas-nombre", { opacity: 0 });
        gsap.to("#fn-mariposas-nombre", {
            opacity: 1,
            duration: 1.6,
            ease: "sine.out",
            delay: 0.8,
        });

        // FLORES IZQUIERDA - Salen de la izquierda
        gsap.fromTo(
            "#flores-foto-izq",
            { opacity: 0, x: -150 },
            { opacity: 1, x: 0, duration: 1.5, ease: "power2.out", delay: 0.7 },
        );

        // FLORES DERECHA - Salen de la derecha
        gsap.fromTo(
            "#flores-foto-der",
            { opacity: 0, x: 150 },
            { opacity: 1, x: 0, duration: 1.5, ease: "power2.out", delay: 0.7 },
        );

        // NOMBRE - Efecto cascada letra por letra con salto de línea entre "Nicol" y "Melany"
        function nombreCascadaElegante() {
            const linea1 = "Fátima";
            const linea2 = "Lucilia";
            const contenedor = document.getElementById("nombre-typewriter");
            if (!contenedor) return;

            // Letras de la primera línea
            const letrasLinea1 = linea1
                .split("")
                .map(
                    (letra, index) =>
                        `<span class="letra-cascada" style="
                            --i: ${index};
                            opacity: 0; 
                            display: inline-block; 
                            transform: translateY(30px) scale(0.8);
                            filter: blur(2px);
                        ">${letra}</span>`,
                )
                .join("");

            // Letras de la segunda línea (índice continúa para stagger fluido)
            const letrasLinea2 = linea2
                .split("")
                .map(
                    (letra, index) =>
                        `<span class="letra-cascada" style="
                            --i: ${linea1.length + index};
                            opacity: 0; 
                            display: inline-block; 
                            transform: translateY(30px) scale(0.8);
                            filter: blur(2px);
                        ">${letra}</span>`,
                )
                .join("");

            // Dos líneas separadas por un salto de línea
            contenedor.innerHTML = `
                <span class="block">${letrasLinea1}</span>
                <span class="block">${letrasLinea2}</span>
            `;

            gsap.to(".letra-cascada", {
                opacity: 1,
                y: 0,
                scale: 1,
                filter: "blur(0px)",
                duration: 0.8,
                ease: "back.out(1.6)",
                stagger: { each: 0.12, from: "start" },
            });
        }

        // IMAGEN PRINCIPAL - Fade in con zoom
        gsap.fromTo(
            "#foto-container",
            { opacity: 0, scale: 0.8, y: 30 },
            { opacity: 1, scale: 1, y: 0, duration: 1.2, ease: "power2.out" },
        );

        nombreCascadaElegante();
        console.log("Animaciones listas!");
    });
</script>

<style>
    /* Forzar opacidad completa en flores superiores */
    #flores-arriba,
    #flores-arriba img {
        opacity: 1 !important;
    }

    /* Trayectorias de vuelo (sin scaleX — el flip lo hace aletear-izq en la img) */
    @keyframes volar1 {
        0%   { transform: translate(  0px,   0px) rotate(-5deg); }
        25%  { transform: translate(-10px, -14px) rotate( 4deg); }
        50%  { transform: translate(  6px, -22px) rotate(-3deg); }
        75%  { transform: translate( -8px, -10px) rotate( 5deg); }
        100% { transform: translate(  0px,   0px) rotate(-5deg); }
    }
    @keyframes volar2 {
        0%   { transform: translate(  0px,   0px) rotate( 3deg); }
        25%  { transform: translate(  8px, -18px) rotate(-4deg); }
        50%  { transform: translate( -5px, -28px) rotate( 6deg); }
        75%  { transform: translate( 10px, -12px) rotate(-3deg); }
        100% { transform: translate(  0px,   0px) rotate( 3deg); }
    }
    @keyframes volar3 {
        0%   { transform: translate(  0px,   0px) rotate( 4deg); }
        30%  { transform: translate(-12px, -16px) rotate(-5deg); }
        60%  { transform: translate(  8px, -24px) rotate( 3deg); }
        80%  { transform: translate( -6px,  -8px) rotate(-4deg); }
        100% { transform: translate(  0px,   0px) rotate( 4deg); }
    }
    @keyframes volar4 {
        0%   { transform: translate(  0px,   0px) rotate( 4deg); }
        30%  { transform: translate( 12px, -16px) rotate(-5deg); }
        60%  { transform: translate( -8px, -24px) rotate( 3deg); }
        80%  { transform: translate(  6px,  -8px) rotate(-4deg); }
        100% { transform: translate(  0px,   0px) rotate( 4deg); }
    }

    /* Aleteo suave — lado derecho */
    @keyframes aletear {
        0%, 100% { transform: scaleX(1);   }
        50%       { transform: scaleX(0.6); }
    }
    /* Aleteo suave — lado izquierdo (espejada) */
    @keyframes aletear-izq {
        0%, 100% { transform: scaleX(-1);   }
        50%       { transform: scaleX(-0.6); }
    }

    .letra-cascada {
        transition: all 0.3s ease;
        will-change: transform, opacity, filter;
        position: relative;
    }

    .letra-cascada:hover {
        transform: translateY(-3px) scale(1.05) !important;
        text-shadow: 0 0 12px rgba(78, 104, 75, 0.5) !important;
    }
</style>
